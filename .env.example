# ── LLM Provider API Keys ──────────────────────────────────────────────────
# At least one is required to run the proxy server.
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# ── Proxy Server ───────────────────────────────────────────────────────────
TSLAYER_HOST=0.0.0.0
TSLAYER_PORT=8080

# Preferred provider for routing (anthropic | openai)
TSLAYER_PREFERRED_PROVIDER=anthropic

# Semantic cache similarity threshold (0.0–1.0). 0.90 = ~6 bit tolerance.
TSLAYER_SIMILARITY_THRESHOLD=0.90

# Cache entry time-to-live in seconds (default: 1 hour)
TSLAYER_CACHE_TTL=3600

# Set to "true" to disable semantic cache (exact-match only)
TSLAYER_DISABLE_CACHE=false

# Set to "true" to disable smart routing (all requests → most capable model)
TSLAYER_DISABLE_ROUTING=false

# ── Embedding Model ──────────────────────────────────────────────────────────
# Sentence-transformers model for semantic cache similarity.
# Default: all-MiniLM-L6-v2 (384-dim, 80MB, English-optimised)
# For multilingual projects (Turkish / French / etc.):
# TSLAYER_EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2
# For best quality (slower, larger):
# TSLAYER_EMBEDDING_MODEL=all-mpnet-base-v2
# TSLAYER_EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── Optional: Redis for distributed cache ──────────────────────────────────
# If set, Redis is used for exact-match cache instead of in-process dict.
# REDIS_URL=redis://localhost:6379/0

# ── Logging ───────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
